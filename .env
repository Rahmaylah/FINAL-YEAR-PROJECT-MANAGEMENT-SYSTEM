SECRET_KEY=django-insecure-7$#8x!@9p&3q#k5$n^m2%z*9x&7g$#8x!@9p&3q#k5$n^m2%z*9x&7g
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DATABASE SETTINGS (PostgreSQL with pgvector)
# ============================================================================
DB_NAME=fypms_db
DB_USER=postgres
DB_PASSWORD=robetho
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# EMBEDDINGS & ML SETTINGS
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DIM=768

# ============================================================================
# DUPLICATE DETECTION SETTINGS
# ============================================================================
DUPLICATE_SIMILARITY_THRESHOLD=0.6
DUPLICATE_AUTO_FLAG_THRESHOLD=0.8
DUPLICATE_SEARCH_YEARS_BACK=3
SEMANTIC_WEIGHT=0.7
DUPLICATE_ALGORITHM=HYBRID

# ============================================================================
# MENTOR ASSIGNMENT SETTINGS
# ============================================================================
MENTOR_MAX_LOAD_DEFAULT=10

# ============================================================================
# CORS SETTINGS (for frontend)
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================================
# EMAIL SETTINGS (Optional - for notifications)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com

# ============================================================================
# LOGGING SETTINGS
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/fypms.log

# ============================================================================
# API SETTINGS
# ============================================================================
API_VERSION=v1
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# ============================================================================
# FRONTEND SETTINGS
# ============================================================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ============================================================================
# SECURITY SETTINGS (Production)
# ============================================================================
